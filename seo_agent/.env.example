# ---- Your site ----
OWN_DOMAIN=jypragroup.com.au
OWN_BRAND=Jypra Group

# ---- SerpAPI (live Google rank tracking) ----
# Free tier = 100 searches/month: https://serpapi.com
SERPAPI_KEY=your_serpapi_key_here
SERP_LOCATION=Brisbane, Queensland, Australia
SERP_GL=au
SERP_HL=en

# ---- LLM provider: replicate | anthropic | openai ----
LLM_PROVIDER=replicate
REPLICATE_API_TOKEN=your_replicate_token_here
REPLICATE_MODEL=meta/meta-llama-3.1-405b-instruct
# ANTHROPIC_API_KEY=your_key
# OPENAI_API_KEY=your_key

# ---- Run controls ----
MAX_KEYWORDS=10
COMPETITORS_PER_KEYWORD=3
